// Grafana Alloy config — ships BOTH metrics and logs to Grafana Cloud.
// No Docker required: Alloy is a single native binary.
//
// Fill in the 5 <PLACEHOLDER> values from your Grafana Cloud account
// (Connections → Add new connection → "Hosted Prometheus" and "Hosted Logs",
//  or your stack's "Details" page generates these for you).
//
// Run:  alloy run config.alloy

// ─────────────────────────── METRICS ───────────────────────────
// Scrape the FastAPI /metrics endpoint, push to Grafana Cloud Prometheus.

prometheus.scrape "resume_ranker" {
  targets      = [{ __address__ = "localhost:8000", job = "resume-ranker" }]
  metrics_path = "/metrics"
  scrape_interval = "15s"
  forward_to   = [prometheus.remote_write.grafana_cloud.receiver]
}

prometheus.remote_write "grafana_cloud" {
  endpoint {
    url = "<PROMETHEUS_REMOTE_WRITE_URL>"   // e.g. https://prometheus-prod-XX.grafana.net/api/prom/push
    basic_auth {
      username = "<PROMETHEUS_USERNAME>"     // a numeric instance id
      password = "<GRAFANA_CLOUD_API_TOKEN>" // a token with metrics-push scope
    }
  }
}

// ──────────────────────────── LOGS ─────────────────────────────
// Tail the app's rotating log file, push to Grafana Cloud Loki.

local.file_match "app_logs" {
  path_targets = [{
    __path__ = "C:/Users/sanch/Desktop/ResumeRanker/backend/logs/app.log",
    job      = "resume-ranker",
  }]
}

loki.source.file "app_logs" {
  targets    = local.file_match.app_logs.targets
  forward_to = [loki.write.grafana_cloud.receiver]
}

loki.write "grafana_cloud" {
  endpoint {
    url = "<LOKI_PUSH_URL>"                  // e.g. https://logs-prod-XX.grafana.net/loki/api/v1/push
    basic_auth {
      username = "<LOKI_USERNAME>"           // a numeric instance id (different from Prometheus)
      password = "<GRAFANA_CLOUD_API_TOKEN>" // can reuse a token with logs-push scope
    }
  }
}
