{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Resume Ranker — Observability",
  "tags": ["resume-ranker"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Token usage rate (tokens/sec by kind)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (kind) (rate(openai_tokens_total[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total tokens by endpoint",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (endpoint) (openai_tokens_total)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache hit ratio",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "orange", "value": 0.3 },
            { "color": "green", "value": 0.6 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(app_cache_events_total{result=\"hit\"}) / clamp_min(sum(app_cache_events_total), 1)",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "OpenAI request rate (req/sec by endpoint)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (endpoint) (rate(openai_requests_total[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP p95 latency (s) by path",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(http_request_seconds_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ]
    }
  ]
}
