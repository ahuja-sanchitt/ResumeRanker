# Copy to .env and fill in. Never commit the real .env.

# OpenAI — required for scoring + interview prep
OPENAI_API_KEY=sk-...

# Redis — optional. If unset, the app falls back to an in-memory cache (fine for local dev).
# For free hosted Redis, create an Upstash database and paste its connection URL here:
#   rediss://default:<password>@<host>:<port>
REDIS_URL=

# CORS — comma-separated allowed origins for the frontend.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Cold email feature (optional; the rest of the app works without these) ---

# Hunter.io — contact discovery. Free tier at hunter.io. Without it, /contacts 503s.
HUNTER_API_KEY=

# Google OAuth (Gmail draft creation). Create an OAuth 2.0 Client (type: Web app)
# in Google Cloud Console, enable the Gmail API, and add the redirect URI below.
# Keep the OAuth consent screen in "Testing" mode and add yourself as a test user.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Where the backend redirects after OAuth (your frontend).
FRONTEND_URL=http://localhost:5173

# Model + tuning overrides (optional; sensible defaults in config.py)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_WEIGHT=0.6
# PREP_CACHE_TTL_SECONDS=604800
